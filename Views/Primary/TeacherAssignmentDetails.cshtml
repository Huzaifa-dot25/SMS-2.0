@model StudentManagementSystem.Models.TeacherAssignment

@{
    ViewData["Title"] = "Teacher Assignment Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-header bg-warning text-white py-3" style="border-radius: 20px 20px 0 0;">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-user-tie me-2"></i>Teacher Assignment Details</h4>
                        <div>
                            <a asp-action="TeacherAssignmentEdit" asp-route-id="@Model.AssignmentID" class="btn btn-light btn-sm">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <a asp-action="TeacherAssignment" class="btn btn-outline-light btn-sm">
                                <i class="fas fa-arrow-left me-1"></i>Back to List
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <!-- Teacher Info Card -->
                        <div class="col-md-4 text-center mb-4">
                            <div class="bg-@Model.BadgeColor text-white rounded-circle p-3 d-inline-flex align-items-center justify-content-center mb-3" style="width:120px;height:120px;">
                                <span class="fw-bold" style="font-size: 2rem;">@Model.Initials</span>
                            </div>
                            <h3 class="mb-1">@Model.TeacherName</h3>
                            <p class="text-muted mb-2">ID: @Model.TeacherID</p>
                            <span class="badge bg-@Model.BadgeColor fs-6">@Model.AssignmentType</span>
                        </div>

                        <!-- Detailed Information -->
                        <div class="col-md-8">
                            <!-- Assignment Information -->
                            <div class="mb-4">
                                <h5 class="text-warning border-bottom pb-2 mb-3">
                                    <i class="fas fa-chalkboard-teacher me-2"></i>Assignment Information
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Class & Section:</strong> @Model.ClassSection
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Subject:</strong> @Model.Subject
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Assignment Type:</strong> <span class="badge bg-@Model.BadgeColor">@Model.AssignmentType</span>
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Status:</strong> 
                                        @if (Model.Status == "Active")
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@Model.Status</span>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Assignment Period -->
                            <div class="mb-4">
                                <h5 class="text-warning border-bottom pb-2 mb-3">
                                    <i class="fas fa-calendar-alt me-2"></i>Assignment Period
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Academic Year:</strong> @(Model.AcademicYear ?? "Not specified")
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Start Date:</strong> @(Model.StartDate?.ToShortDateString() ?? "Not specified")
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>End Date:</strong> @(Model.EndDate?.ToShortDateString() ?? "Not specified")
                                    </div>
                                </div>
                            </div>

                            <!-- Additional Information -->
                            @if (!string.IsNullOrEmpty(Model.Notes))
                            {
                                <div class="mb-4">
                                    <h5 class="text-warning border-bottom pb-2 mb-3">
                                        <i class="fas fa-sticky-note me-2"></i>Notes
                                    </h5>
                                    <p class="text-muted">@Model.Notes</p>
                                </div>
                            }

                            <!-- System Information -->
                            <div class="mb-4">
                                <h5 class="text-warning border-bottom pb-2 mb-3">
                                    <i class="fas fa-info-circle me-2"></i>System Information
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Created Date:</strong> @Model.CreatedDate.ToShortDateString()
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Last Modified:</strong> @(Model.ModifiedDate?.ToShortDateString() ?? "Never")
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="mt-4 pt-3 border-top">
                        <div class="d-flex justify-content-between">
                            <a asp-action="TeacherAssignment" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <div>
                                <a asp-action="TeacherAssignmentEdit" asp-route-id="@Model.AssignmentID" class="btn btn-warning me-2">
                                    <i class="fas fa-edit me-2"></i>Edit Assignment
                                </a>
                                <a asp-action="TeacherAssignmentDelete" asp-route-id="@Model.AssignmentID" class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
