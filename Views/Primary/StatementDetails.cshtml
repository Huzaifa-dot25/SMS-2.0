@model StudentManagementSystem.Models.Statement

@{
    ViewData["Title"] = "Statement Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-header bg-success text-white py-3" style="border-radius: 20px 20px 0 0;">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-comment-dots me-2"></i>Statement Details</h4>
                        <div>
                            <a asp-action="StatementEdit" asp-route-id="@Model.StatementID" class="btn btn-light btn-sm">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <a asp-action="ManageStatements" class="btn btn-outline-light btn-sm">
                                <i class="fas fa-arrow-left me-1"></i>Back to List
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row">
                        <!-- Statement Preview -->
                        <div class="col-md-4 text-center mb-4">
                            <div class="bg-@Model.CategoryBadge text-white rounded-4 p-4 mb-3">
                                <i class="fas fa-comment-dots fa-3x mb-2"></i>
                                <h5 class="mb-2">@Model.Category</h5>
                                <span class="badge bg-light text-dark">@Model.StatementType</span>
                            </div>
                            <div class="text-start">
                                <div class="mb-2">
                                    <strong>Status:</strong> 
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </div>
                                <div class="mb-2">
                                    <strong>Usage Count:</strong> @Model.UsageCount
                                </div>
                            </div>
                        </div>

                        <!-- Detailed Information -->
                        <div class="col-md-8">
                            <!-- Statement Content -->
                            <div class="mb-4">
                                <h5 class="text-success border-bottom pb-2 mb-3">
                                    <i class="fas fa-quote-left me-2"></i>Statement Content
                                </h5>
                                <div class="bg-light rounded-3 p-3">
                                    <p class="mb-0 fst-italic">@Model.StatementText</p>
                                </div>
                            </div>

                            <!-- Classification -->
                            <div class="mb-4">
                                <h5 class="text-success border-bottom pb-2 mb-3">
                                    <i class="fas fa-tags me-2"></i>Classification
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Category:</strong> <span class="badge bg-@Model.CategoryBadge">@Model.Category</span>
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Statement Type:</strong> <span class="badge bg-@Model.TypeBadge">@Model.StatementType</span>
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Subcategory:</strong> @(Model.Subcategory ?? "Not specified")
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Subject Specific:</strong> @(Model.SubjectSpecific ?? "General")
                                    </div>
                                </div>
                            </div>

                            <!-- Targeting -->
                            <div class="mb-4">
                                <h5 class="text-success border-bottom pb-2 mb-3">
                                    <i class="fas fa-bullseye me-2"></i>Targeting
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Target Class:</strong> @(Model.TargetClass ?? "All Classes")
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Target Section:</strong> @(Model.TargetSection ?? "All Sections")
                                    </div>
                                </div>
                            </div>

                            <!-- Additional Information -->
                            @if (!string.IsNullOrEmpty(Model.Notes))
                            {
                                <div class="mb-4">
                                    <h5 class="text-success border-bottom pb-2 mb-3">
                                        <i class="fas fa-sticky-note me-2"></i>Notes
                                    </h5>
                                    <p class="text-muted">@Model.Notes</p>
                                </div>
                            }

                            <!-- System Information -->
                            <div class="mb-4">
                                <h5 class="text-success border-bottom pb-2 mb-3">
                                    <i class="fas fa-info-circle me-2"></i>System Information
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Created By:</strong> @(Model.CreatedBy ?? "Unknown")
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Created Date:</strong> @Model.CreatedDate.ToShortDateString()
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Last Modified:</strong> @(Model.ModifiedDate?.ToShortDateString() ?? "Never")
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="mt-4 pt-3 border-top">
                        <div class="d-flex justify-content-between">
                            <a asp-action="ManageStatements" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Statements
                            </a>
                            <div>
                                <a asp-action="StatementEdit" asp-route-id="@Model.StatementID" class="btn btn-success me-2">
                                    <i class="fas fa-edit me-2"></i>Edit Statement
                                </a>
                                <a asp-action="StatementDelete" asp-route-id="@Model.StatementID" class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
