@model StudentManagementSystem.Models.Statement

@{
    ViewData["Title"] = "Delete Statement";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm" style="border-radius: 20px;">
                <div class="card-header bg-danger text-white py-3" style="border-radius: 20px 20px 0 0;">
                    <h4 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Statement</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning d-flex align-items-center" role="alert">
                        <i class="fas fa-exclamation-triangle me-3 fa-2x"></i>
                        <div>
                            <strong>Warning:</strong> Are you sure you want to delete this statement? This action cannot be undone.
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 text-center mb-4">
                            <div class="bg-@Model.CategoryBadge text-white rounded-4 p-3 d-inline-flex align-items-center justify-content-center mb-3" style="width:100px;height:100px;">
                                <i class="fas fa-comment-dots fa-2x"></i>
                            </div>
                            <h5 class="mb-1">@Model.Category</h5>
                            <p class="text-muted mb-2">@Model.StatementType</p>
                            <span class="badge bg-@Model.TypeBadge">@Model.StatementType</span>
                        </div>

                        <div class="col-md-8">
                            <h5 class="text-primary border-bottom pb-2 mb-3">Statement Information</h5>
                            
                            <div class="row mb-3">
                                <div class="col-sm-3">
                                    <strong>Statement:</strong>
                                </div>
                                <div class="col-sm-9">
                                    <p class="text-muted mb-0">"@Model.StatementText"</p>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-3">
                                    <strong>Category:</strong>
                                </div>
                                <div class="col-sm-9">
                                    <span class="badge bg-@Model.CategoryBadge">@Model.Category</span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-3">
                                    <strong>Statement Type:</strong>
                                </div>
                                <div class="col-sm-9">
                                    <span class="badge bg-@Model.TypeBadge">@Model.StatementType</span>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Subcategory))
                            {
                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <strong>Subcategory:</strong>
                                    </div>
                                    <div class="col-sm-9">
                                        @Model.Subcategory
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.SubjectSpecific))
                            {
                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <strong>Subject:</strong>
                                    </div>
                                    <div class="col-sm-9">
                                        @Model.SubjectSpecific
                                    </div>
                                </div>
                            }

                            <div class="row mb-3">
                                <div class="col-sm-3">
                                    <strong>Status:</strong>
                                </div>
                                <div class="col-sm-9">
                                    @if (Model.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-3">
                                    <strong>Usage Count:</strong>
                                </div>
                                <div class="col-sm-9">
                                    @Model.UsageCount times
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Notes))
                            {
                                <div class="row mb-3">
                                    <div class="col-sm-3">
                                        <strong>Notes:</strong>
                                    </div>
                                    <div class="col-sm-9">
                                        @Model.Notes
                                    </div>
                                </div>
                            }

                            <div class="row mb-3">
                                <div class="col-sm-3">
                                    <strong>Created Date:</strong>
                                </div>
                                <div class="col-sm-9">
                                    @Model.CreatedDate.ToShortDateString()
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="StatementDelete" class="mt-4">
                        <input type="hidden" asp-for="StatementID" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="StatementDetails" asp-route-id="@Model.StatementID" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Details
                            </a>
                            <div>
                                <a asp-action="ManageStatements" class="btn btn-outline-secondary me-2">
                                    <i class="fas fa-ban me-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Delete Statement
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
