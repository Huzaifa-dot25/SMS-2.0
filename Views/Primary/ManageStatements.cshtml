@model IEnumerable<StudentManagementSystem.Models.Statement>

@{
    ViewData["Title"] = "Primary - Manage Statements";
}

<div class="card border-0 shadow-sm" style="border-radius: 20px;">
    <div class="card-header bg-white py-4 px-4 border-0">
        <h4 class="mb-1 fw-bold text-dark"><i class="fas fa-comment-dots me-3 text-success"></i>Manage Descriptive Statements</h4>
        <p class="mb-0 text-muted small">Configure and assign performance comments for primary report cards.</p>
    </div>
    <div class="card-body p-4">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm rounded-4 d-flex align-items-center mb-4">
                <i class="fas fa-check-circle fa-2x me-3"></i>
                <div>
                    <strong>Success:</strong> @TempData["SuccessMessage"]
                </div>
            </div>
        }

        <div class="row mb-4">
            <div class="col-md-4">
                <div class="p-4 bg-light rounded-4 h-100 border-0 shadow-none">
                    <h6 class="fw-bold mb-3">Add New Statement</h6>
                    <form asp-action="StatementCreate" method="post">
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Category</label>
                            <select name="Category" class="form-select border-0 shadow-sm">
                                <option value="">Select Category</option>
                                <option value="Academic Performance">Academic Performance</option>
                                <option value="Behavioral Conduct">Behavioral Conduct</option>
                                <option value="Extracurricular">Extracurricular</option>
                                <option value="Attendance">Attendance</option>
                                <option value="Homework">Homework</option>
                                <option value="Participation">Participation</option>
                                <option value="Social Skills">Social Skills</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Statement Type</label>
                            <select name="StatementType" class="form-select border-0 shadow-sm">
                                <option value="Positive">Positive</option>
                                <option value="Needs Improvement">Needs Improvement</option>
                                <option value="Concern">Concern</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Statement Text</label>
                            <textarea name="StatementText" class="form-control border-0 shadow-sm" rows="4" placeholder="e.g. Shows great interest in mathematics and logical reasoning." required></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100 rounded-pill shadow-sm py-2">
                            <i class="fas fa-plus me-2"></i>Save Statement
                        </button>
                    </form>
                </div>
            </div>
            <div class="col-md-8">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-muted mb-0">EXISTING STATEMENTS (@Model.Count())</h6>
                    <div class="input-group input-group-sm" style="width: 250px;">
                        <form asp-action="ManageStatements" method="get" class="d-flex">
                            <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control border-0 bg-light" placeholder="Search statements...">
                            <button type="submit" class="input-group-text border-0 bg-light">
                                <i class="fas fa-search"></i>
                            </button>
                        </form>
                    </div>
                </div>
                <div class="table-responsive rounded-3 border">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 120px;">Category</th>
                                <th>Type</th>
                                <th>Statement</th>
                                <th class="text-end" style="width: 100px;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><span class="badge bg-@item.CategoryBadge.ToLower()">@item.Category</span></td>
                                        <td><span class="badge bg-@item.TypeBadge.ToLower()">@item.StatementType</span></td>
                                        <td class="small" title="@item.StatementText">@item.TruncatedText</td>
                                        <td class="text-end">
                                            <div class="btn-group">
                                                <a asp-action="StatementDetails" asp-route-id="@item.StatementID" class="btn btn-link btn-sm text-primary p-0 me-2" title="View Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a asp-action="StatementEdit" asp-route-id="@item.StatementID" class="btn btn-link btn-sm text-warning p-0 me-2" title="Edit">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a asp-action="StatementDelete" asp-route-id="@item.StatementID" class="btn btn-link btn-sm text-danger p-0" title="Delete">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">
                                        <i class="fas fa-comment-dots fa-3x mb-3 opacity-25"></i>
                                        <p class="mb-0">No statements found. Add your first statement using the form on the left.</p>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
                {
                    <div class="mt-3">
                        <a asp-action="ManageStatements" class="btn btn-link text-decoration-none">
                            <i class="fas fa-times me-1"></i> Clear Search
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
    .bg-soft-warning { background-color: rgba(255, 193, 7, 0.1); }
    .bg-soft-danger { background-color: rgba(220, 53, 69, 0.1); }
    .bg-soft-primary { background-color: rgba(13, 110, 253, 0.1); }
    .bg-soft-secondary { background-color: rgba(108, 117, 125, 0.1); }
    .bg-soft-dark { background-color: rgba(33, 37, 41, 0.1); }
    .bg-soft-light { background-color: rgba(248, 249, 250, 0.1); }
</style>
