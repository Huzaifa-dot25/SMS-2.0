@{
    ViewData["Title"] = "Primary - Manage Statements";
}

<div class="card border-0 shadow-sm" style="border-radius: 20px;">
    <div class="card-header bg-white py-4 px-4 border-0">
        <h4 class="mb-1 fw-bold text-dark"><i class="fas fa-comment-dots me-3 text-success"></i>Manage Descriptive Statements</h4>
        <p class="mb-0 text-muted small">Configure and assign performance comments for primary report cards.</p>
    </div>
    <div class="card-body p-4">
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="p-4 bg-light rounded-4 h-100 border-0 shadow-none">
                    <h6 class="fw-bold mb-3">Add New Statement</h6>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Category</label>
                        <select class="form-select border-0 shadow-sm">
                            <option>Academic Performance</option>
                            <option>Behavioral Conduct</option>
                            <option>Extracurricular</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Statement Text</label>
                        <textarea class="form-control border-0 shadow-sm" rows="4" placeholder="e.g. Shows great interest in mathematics and logical reasoning."></textarea>
                    </div>
                    <button class="btn btn-success w-100 rounded-pill shadow-sm py-2">Save Statement</button>
                </div>
            </div>
            <div class="col-md-8">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h6 class="fw-bold text-muted mb-0">EXISTING STATEMENTS</h6>
                    <div class="input-group input-group-sm" style="width: 250px;">
                        <input type="text" class="form-control border-0 bg-light" placeholder="Search statements...">
                        <span class="input-group-text border-0 bg-light"><i class="fas fa-search"></i></span>
                    </div>
                </div>
                <div class="table-responsive rounded-3 border">
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th style="width: 150px;">Category</th>
                                <th>Statement</th>
                                <th class="text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><span class="badge bg-soft-success text-success">Academic</span></td>
                                <td class="small">The student demonstrates a deep understanding of core concepts and consistently participates in class.</td>
                                <td class="text-end">
                                    <button class="btn btn-link btn-sm text-primary p-0 me-2"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-link btn-sm text-danger p-0"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                            <tr>
                                <td><span class="badge bg-soft-info text-info">Behavioral</span></td>
                                <td class="small">Displays excellent teamwork skills and respects peers' opinions during group activities.</td>
                                <td class="text-end">
                                    <button class="btn btn-link btn-sm text-primary p-0 me-2"><i class="fas fa-edit"></i></button>
                                    <button class="btn btn-link btn-sm text-danger p-0"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-success { background-color: rgba(25, 135, 84, 0.1); }
    .bg-soft-info { background-color: rgba(13, 202, 240, 0.1); }
</style>
