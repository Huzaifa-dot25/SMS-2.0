@{
    ViewData["Title"] = "Primary Dashboard";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold text-dark mb-1">Primary Assessment</h2>
            <p class="text-muted">Manage results, assignments, and statements for primary sections.</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 hover-card">
                <div class="icon-box bg-primary-light mb-3 mx-auto">
                    <i class="fas fa-calendar-check fa-2x text-primary"></i>
                </div>
                <h5 class="fw-bold">Manage Result</h5>
                <p class="text-muted small">Enter and update examination marks for primary students.</p>
                <a asp-action="ManageResult" class="btn btn-outline-primary rounded-pill stretched-link">Go to Results</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 hover-card">
                <div class="icon-box bg-info-light mb-3 mx-auto">
                    <i class="fas fa-print fa-2x text-info"></i>
                </div>
                <h5 class="fw-bold">Print Result</h5>
                <p class="text-muted small">Generate and print student report cards.</p>
                <a asp-action="PrintResult" class="btn btn-outline-info rounded-pill stretched-link">Print Now</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 hover-card">
                <div class="icon-box bg-warning-light mb-3 mx-auto">
                    <i class="fas fa-graduation-cap fa-2x text-warning"></i>
                </div>
                <h5 class="fw-bold">Teacher Assignment</h5>
                <p class="text-muted small">Assign teachers to specific subjects and classes.</p>
                <a asp-action="TeacherAssignment" class="btn btn-outline-warning rounded-pill stretched-link">Manage Assignments</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 hover-card">
                <div class="icon-box bg-success-light mb-3 mx-auto">
                    <i class="fas fa-comment-dots fa-2x text-success"></i>
                </div>
                <h5 class="fw-bold">Manage Statements</h5>
                <p class="text-muted small">Add descriptive feedback and comments for reports.</p>
                <a asp-action="ManageStatements" class="btn btn-outline-success rounded-pill stretched-link">Manage Statements</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 hover-card">
                <div class="icon-box bg-danger-light mb-3 mx-auto">
                    <i class="fas fa-users-rectangle fa-2x text-danger"></i>
                </div>
                <h5 class="fw-bold">View Statements by Class</h5>
                <p class="text-muted small">View all student statements summarized by class.</p>
                <a asp-action="ViewStatementsByClass" class="btn btn-outline-danger rounded-pill stretched-link">View Statements</a>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-light { background-color: rgba(54, 153, 255, 0.1); }
    .bg-success-light { background-color: rgba(27, 197, 189, 0.1); }
    .bg-info-light { background-color: rgba(137, 80, 252, 0.1); }
    .bg-warning-light { background-color: rgba(255, 168, 0, 0.1); }
    .bg-danger-light { background-color: rgba(246, 78, 96, 0.1); }
    .icon-box { width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 12px; }
    .hover-card { transition: all 0.3s cubic-bezier(.25,.8,.25,1); border-radius: 16px !important; }
    .hover-card:hover { transform: translateY(-10px); box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important; }
</style>
