@model StudentManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="fas fa-user-tie me-2"></i>Employee Details</h4>
                        <div>
                            <a asp-action="Edit" asp-route-id="@Model.EmployeeID" class="btn btn-light btn-sm">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <a asp-action="Index" class="btn btn-outline-light btn-sm">
                                <i class="fas fa-arrow-left me-1"></i>Back to List
                            </a>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Profile Photo and Basic Info -->
                        <div class="col-md-4 text-center mb-4">
                            @if (!string.IsNullOrEmpty(Model.PhotoPath))
                            {
                                <img src="@Model.PhotoPath" alt="Employee Photo" class="rounded-circle shadow-lg mb-3" style="width:200px;height:200px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center text-primary mx-auto mb-3" style="width:200px;height:200px;">
                                    <i class="fas fa-user-tie fa-4x"></i>
                                </div>
                            }
                            <h3 class="mb-1">@Model.FullName</h3>
                            <p class="text-muted mb-2">@Model.JobTitle</p>
                            <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary") fs-6">@Model.Status</span>
                        </div>

                        <!-- Detailed Information -->
                        <div class="col-md-8">
                            <!-- Personal Information -->
                            <div class="mb-4">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-user me-2"></i>Personal Information
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Employee Code:</strong> <span class="badge bg-light text-dark">@Model.EmployeeCode</span>
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Date of Birth:</strong> @(Model.DateOfBirth?.ToShortDateString() ?? "N/A")
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Gender:</strong> @Model.Gender
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Age:</strong> @Model.Age
                                    </div>
                                </div>
                            </div>

                            <!-- Contact Information -->
                            <div class="mb-4">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-address-book me-2"></i>Contact Information
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Email:</strong> <a href="mailto:@Model.Email">@Model.Email</a>
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Phone:</strong> @Model.PhoneNumber
                                    </div>
                                    <div class="col-12 mb-2">
                                        <strong>Address:</strong> @(Model.Address ?? "N/A")
                                    </div>
                                </div>
                            </div>

                            <!-- Employment Information -->
                            <div class="mb-4">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-briefcase me-2"></i>Employment Information
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Department:</strong> @Model.Department
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Job Title:</strong> @Model.JobTitle
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Employment Type:</strong> @Model.EmploymentType
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Joining Date:</strong> @Model.JoiningDate.ToShortDateString()
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Years of Service:</strong> @Model.YearsOfService
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Salary:</strong> @(Model.Salary?.ToString("C") ?? "N/A")
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Work Location:</strong> @(Model.WorkLocation ?? "N/A")
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Manager:</strong> @(Model.Manager?.FullName ?? "N/A")
                                    </div>
                                </div>
                            </div>

                            <!-- Emergency Contact -->
                            @if (!string.IsNullOrEmpty(Model.EmergencyContact))
                            {
                                <div class="mb-4">
                                    <h5 class="text-primary border-bottom pb-2 mb-3">
                                        <i class="fas fa-phone-alt me-2"></i>Emergency Contact
                                    </h5>
                                    <div class="row">
                                        <div class="col-sm-6 mb-2">
                                            <strong>Contact Name:</strong> @Model.EmergencyContact
                                        </div>
                                        <div class="col-sm-6 mb-2">
                                            <strong>Emergency Phone:</strong> @Model.EmergencyPhone
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- System Information -->
                            <div class="mb-4">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-info-circle me-2"></i>System Information
                                </h5>
                                <div class="row">
                                    <div class="col-sm-6 mb-2">
                                        <strong>Created Date:</strong> @Model.CreatedDate.ToShortDateString()
                                    </div>
                                    <div class="col-sm-6 mb-2">
                                        <strong>Last Modified:</strong> @(Model.ModifiedDate?.ToShortDateString() ?? "Never")
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Subordinates Section -->
                    @if (Model.Subordinates != null && Model.Subordinates.Any())
                    {
                        <div class="mt-4">
                            <h5 class="text-primary border-bottom pb-2 mb-3">
                                <i class="fas fa-users me-2"></i>Subordinates (@Model.Subordinates.Count)
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>Employee Code</th>
                                            <th>Name</th>
                                            <th>Job Title</th>
                                            <th>Department</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var subordinate in Model.Subordinates)
                                        {
                                            <tr>
                                                <td><span class="badge bg-light text-dark">@subordinate.EmployeeCode</span></td>
                                                <td>
                                                    <a asp-action="Details" asp-route-id="@subordinate.EmployeeID" class="text-decoration-none">
                                                        @subordinate.FullName
                                                    </a>
                                                </td>
                                                <td>@subordinate.JobTitle</td>
                                                <td>@subordinate.Department</td>
                                                <td>
                                                    <span class="badge @(subordinate.Status == "Active" ? "bg-success" : "bg-secondary")">
                                                        @subordinate.Status
                                                    </span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <!-- Documents Section -->
                    @if (Model.Documents != null && Model.Documents.Any())
                    {
                        <div class="mt-4">
                            <h5 class="text-primary border-bottom pb-2 mb-3">
                                <i class="fas fa-file-alt me-2"></i>Documents (@Model.Documents.Count)
                            </h5>
                            <div class="table-responsive">
                                <table class="table table-sm table-hover">
                                    <thead class="bg-light">
                                        <tr>
                                            <th>Document Name</th>
                                            <th>Type</th>
                                            <th>Upload Date</th>
                                            <th>Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var document in Model.Documents)
                                        {
                                            <tr>
                                                <td>@document.DocumentName</td>
                                                <td><span class="badge bg-info">@document.DocumentType.ToUpper()</span></td>
                                                <td>@document.UploadDate.ToShortDateString()</td>
                                                <td>
                                                    <a href="@document.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                                        <i class="fas fa-eye me-1"></i>View
                                                    </a>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                    <!-- Action Buttons -->
                    <div class="mt-4 pt-3 border-top">
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <div>
                                <a asp-action="Edit" asp-route-id="@Model.EmployeeID" class="btn btn-primary me-2">
                                    <i class="fas fa-edit me-2"></i>Edit Employee
                                </a>
                                <a asp-action="Delete" asp-route-id="@Model.EmployeeID" class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Delete
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
