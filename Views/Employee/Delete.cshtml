@model StudentManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-user-times me-2"></i>Delete Employee</h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning d-flex align-items-center" role="alert">
                        <i class="fas fa-exclamation-triangle me-3 fa-2x"></i>
                        <div>
                            <strong>Warning:</strong> Are you sure you want to delete this employee? This action cannot be undone.
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 text-center mb-4">
                            @if (!string.IsNullOrEmpty(Model.PhotoPath))
                            {
                                <img src="@Model.PhotoPath" alt="Employee Photo" class="rounded-circle shadow-lg mb-3" style="width:150px;height:150px;object-fit:cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center text-primary mx-auto mb-3" style="width:150px;height:150px;">
                                    <i class="fas fa-user-tie fa-3x"></i>
                                </div>
                            }
                            <h4 class="mb-1">@Model.FullName</h4>
                            <p class="text-muted mb-2">@Model.JobTitle</p>
                            <span class="badge @(Model.Status == "Active" ? "bg-success" : "bg-secondary")">@Model.Status</span>
                        </div>

                        <div class="col-md-8">
                            <h5 class="text-primary border-bottom pb-2 mb-3">Employee Information</h5>
                            
                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>Employee Code:</strong>
                                </div>
                                <div class="col-sm-8">
                                    <span class="badge bg-light text-dark">@Model.EmployeeCode</span>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>Department:</strong>
                                </div>
                                <div class="col-sm-8">
                                    @Model.Department
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>Email:</strong>
                                </div>
                                <div class="col-sm-8">
                                    <a href="mailto:@Model.Email">@Model.Email</a>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>Phone:</strong>
                                </div>
                                <div class="col-sm-8">
                                    @Model.PhoneNumber
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>Joining Date:</strong>
                                </div>
                                <div class="col-sm-8">
                                    @Model.JoiningDate.ToShortDateString()
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-sm-4">
                                    <strong>Years of Service:</strong>
                                </div>
                                <div class="col-sm-8">
                                    @Model.YearsOfService
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(Model.Address))
                            {
                                <div class="row mb-3">
                                    <div class="col-sm-4">
                                        <strong>Address:</strong>
                                    </div>
                                    <div class="col-sm-8">
                                        @Model.Address
                                    </div>
                                </div>
                            }

                            <!-- Check for subordinates -->
                            @if (Model.Subordinates != null && Model.Subordinates.Any())
                            {
                                <div class="alert alert-info mt-3" role="alert">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Note:</strong> This employee has @Model.Subordinates.Count subordinate(s). Deleting this employee may affect their reporting structure.
                                </div>
                            }

                            <!-- Check for documents -->
                            @if (Model.Documents != null && Model.Documents.Any())
                            {
                                <div class="alert alert-info mt-3" role="alert">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Note:</strong> This employee has @Model.Documents.Count document(s) that will also be deleted.
                                </div>
                            }
                        </div>
                    </div>

                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="EmployeeID" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Details" asp-route-id="@Model.EmployeeID" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Details
                            </a>
                            <div>
                                <a asp-action="Index" class="btn btn-outline-secondary me-2">
                                    <i class="fas fa-ban me-2"></i>Cancel
                                </a>
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-trash me-2"></i>Delete Employee
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
