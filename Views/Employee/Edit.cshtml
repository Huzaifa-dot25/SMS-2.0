@model StudentManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0"><i class="fas fa-user-edit me-2"></i>Edit Employee - @Model.FullName</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
                        <input type="hidden" asp-for="EmployeeID" />
                        <input type="hidden" asp-for="CreatedDate" />

                        <!-- Personal Information -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-user me-2"></i>Personal Information
                                </h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label fw-bold"></label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label fw-bold"></label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EmployeeCode" class="form-label fw-bold"></label>
                                <input asp-for="EmployeeCode" class="form-control" readonly />
                                <span asp-validation-for="EmployeeCode" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="DateOfBirth" class="form-label fw-bold"></label>
                                <input asp-for="DateOfBirth" class="form-control" type="date" />
                                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Gender" class="form-label fw-bold"></label>
                                <select asp-for="Gender" class="form-select">
                                    <option value="">Select Gender</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                    <option value="Other">Other</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhotoPath" class="form-label fw-bold">Photo</label>
                                @if (!string.IsNullOrEmpty(Model.PhotoPath))
                                {
                                    <div class="mb-2">
                                        <img src="@Model.PhotoPath" alt="Current Photo" class="rounded-circle" style="width:60px;height:60px;object-fit:cover;" />
                                        <small class="text-muted d-block">Current photo</small>
                                    </div>
                                }
                                <input type="file" name="photoFile" class="form-control" accept="image/*" />
                                <small class="text-muted">Leave empty to keep current photo</small>
                            </div>
                        </div>

                        <!-- Contact Information -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-address-book me-2"></i>Contact Information
                                </h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Email" class="form-label fw-bold"></label>
                                <input asp-for="Email" class="form-control" type="email" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PhoneNumber" class="form-label fw-bold"></label>
                                <input asp-for="PhoneNumber" class="form-control" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                            <div class="col-12 mb-3">
                                <label asp-for="Address" class="form-label fw-bold"></label>
                                <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Employment Information -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-briefcase me-2"></i>Employment Information
                                </h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Department" class="form-label fw-bold"></label>
                                <select asp-for="Department" class="form-select">
                                    <option value="">Select Department</option>
                                    @if (ViewBag.Departments != null)
                                    {
                                        @foreach (var dept in ViewBag.Departments)
                                        {
                                            <option value="@dept" selected="@(dept == Model.Department)">@dept</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="Department" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="JobTitle" class="form-label fw-bold"></label>
                                <select asp-for="JobTitle" class="form-select">
                                    <option value="">Select Job Title</option>
                                    @if (ViewBag.JobTitles != null)
                                    {
                                        @foreach (var title in ViewBag.JobTitles)
                                        {
                                            <option value="@title" selected="@(title == Model.JobTitle)">@title</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="JobTitle" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EmploymentType" class="form-label fw-bold"></label>
                                <select asp-for="EmploymentType" class="form-select">
                                    @if (ViewBag.EmploymentTypes != null)
                                    {
                                        @foreach (var type in ViewBag.EmploymentTypes)
                                        {
                                            <option value="@type" selected="@(type == Model.EmploymentType)">@type</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="EmploymentType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="JoiningDate" class="form-label fw-bold"></label>
                                <input asp-for="JoiningDate" class="form-control" type="date" />
                                <span asp-validation-for="JoiningDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Salary" class="form-label fw-bold"></label>
                                <input asp-for="Salary" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Salary" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="WorkLocation" class="form-label fw-bold"></label>
                                <input asp-for="WorkLocation" class="form-control" />
                                <span asp-validation-for="WorkLocation" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="ManagerID" class="form-label fw-bold">Manager</label>
                                <select asp-for="ManagerID" class="form-select">
                                    <option value="">Select Manager (Optional)</option>
                                    @if (ViewBag.Managers != null)
                                    {
                                        @foreach (var manager in ViewBag.Managers)
                                        {
                                            <option value="@manager.EmployeeID" selected="@(manager.EmployeeID == Model.ManagerID)">
                                                @manager.FullName
                                            </option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="ManagerID" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="Status" class="form-label fw-bold"></label>
                                <select asp-for="Status" class="form-select">
                                    <option value="Active" selected="@(Model.Status == "Active")">Active</option>
                                    <option value="Inactive" selected="@(Model.Status == "Inactive")">Inactive</option>
                                    <option value="On Leave" selected="@(Model.Status == "On Leave")">On Leave</option>
                                    <option value="Terminated" selected="@(Model.Status == "Terminated")">Terminated</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Emergency Contact -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-phone-alt me-2"></i>Emergency Contact
                                </h5>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EmergencyContact" class="form-label fw-bold">Emergency Contact Name</label>
                                <input asp-for="EmergencyContact" class="form-control" />
                                <span asp-validation-for="EmergencyContact" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EmergencyPhone" class="form-label fw-bold">Emergency Phone</label>
                                <input asp-for="EmergencyPhone" class="form-control" />
                                <span asp-validation-for="EmergencyPhone" class="text-danger"></span>
                            </div>
                        </div>

                        <!-- Existing Documents -->
                        @if (Model.Documents != null && Model.Documents.Any())
                        {
                            <div class="row mb-4">
                                <div class="col-12">
                                    <h5 class="text-primary border-bottom pb-2 mb-3">
                                        <i class="fas fa-file-alt me-2"></i>Existing Documents
                                    </h5>
                                    <div class="table-responsive">
                                        <table class="table table-sm">
                                            <thead class="bg-light">
                                                <tr>
                                                    <th>Document Name</th>
                                                    <th>Type</th>
                                                    <th>Upload Date</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var document in Model.Documents)
                                                {
                                                    <tr>
                                                        <td>@document.DocumentName</td>
                                                        <td><span class="badge bg-info">@document.DocumentType.ToUpper()</span></td>
                                                        <td>@document.UploadDate.ToShortDateString()</td>
                                                        <td>
                                                            <a href="@document.FilePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                                                <i class="fas fa-eye me-1"></i>View
                                                            </a>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Upload New Documents -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <h5 class="text-primary border-bottom pb-2 mb-3">
                                    <i class="fas fa-file-upload me-2"></i>Upload New Documents
                                </h5>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label fw-bold">Additional Documents</label>
                                <input type="file" name="documentFiles" class="form-control" multiple accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" />
                                <small class="text-muted">Optional: Upload additional documents (PDF, DOC, DOCX, JPG, JPEG, PNG)</small>
                            </div>
                        </div>

                        <!-- Form Actions -->
                        <div class="row">
                            <div class="col-12">
                                <div class="d-flex justify-content-between">
                                    <a asp-action="Index" class="btn btn-secondary px-4">
                                        <i class="fas fa-arrow-left me-2"></i>Back to List
                                    </a>
                                    <div>
                                        <a asp-action="Details" asp-route-id="@Model.EmployeeID" class="btn btn-outline-secondary me-2">
                                            <i class="fas fa-eye me-2"></i>View Details
                                        </a>
                                        <button type="submit" class="btn btn-primary px-4">
                                            <i class="fas fa-save me-2"></i>Update Employee
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
