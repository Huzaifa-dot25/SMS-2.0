@model IEnumerable<StudentManagementSystem.Models.Student>
@{
    ViewData["Title"] = "Assign Students to Class";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm" style="border-radius: 15px; background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);">
                <div class="card-body p-4 text-white">
                    <div class="d-flex align-items-center">
                        <div class="bg-white bg-opacity-20 rounded-3 p-3 me-3">
                            <i class="fas fa-users-cog fa-2x"></i>
                        </div>
                        <div>
                            <h3 class="mb-1 fw-bold">Class Assignment Module</h3>
                            <p class="mb-0 opacity-75">Efficiently manage student placements and bulk transfer students between classes.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px;">
            <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        <!-- Filter & Action Panel -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm h-100" style="border-radius: 15px;">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4"><i class="fas fa-filter text-primary me-2"></i>Filters</h5>
                    <form method="get" asp-action="AssignStudents">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Current Class</label>
                            <select name="className" class="form-select border-light-subtle bg-light" style="border-radius: 10px;">
                                <option value="">-- All Classes --</option>
                                @if (ViewBag.Classes != null)
                                {
                                    @foreach (var c in ViewBag.Classes)
                                    {
                                        <option value="@c" selected="@(Context.Request.Query["className"] == c)">@c</option>
                                    }
                                }
                                <option value="Unassigned" selected="@(Context.Request.Query["className"] == "Unassigned")">Unassigned</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">Section</label>
                            <select name="section" class="form-select border-light-subtle bg-light" style="border-radius: 10px;">
                                <option value="">-- All Sections --</option>
                                @if (ViewBag.Sections != null)
                                {
                                    @foreach (var s in ViewBag.Sections)
                                    {
                                        <option value="@s" selected="@(Context.Request.Query["section"] == s)">@s</option>
                                    }
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 10px;">
                            <i class="fas fa-search me-2"></i> Filter List
                        </button>
                    </form>

                    <hr class="my-4 opacity-10">

                    <h5 class="fw-bold mb-4"><i class="fas fa-bolt text-warning me-2"></i>Bulk Action</h5>
                    <form asp-action="BulkAssign" method="post" id="bulkForm">
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Target Class</label>
                            <input type="text" name="targetClass" class="form-control border-light-subtle bg-light" placeholder="e.g. Class 1" required style="border-radius: 10px;">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Target Section</label>
                            <input type="text" name="targetSection" class="form-control border-light-subtle bg-light" placeholder="e.g. A" required style="border-radius: 10px;">
                        </div>
                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">Session</label>
                            <select name="targetSession" class="form-select border-light-subtle bg-light" style="border-radius: 10px;">
                                <option value="2024-2025">2024-2025</option>
                                <option value="2025-2026">2025-2026</option>
                            </select>
                        </div>
                        
                        <div id="selectedCount" class="mb-3 small text-center p-2 bg-light rounded-3 text-primary fw-bold" style="display:none;">
                            0 students selected
                        </div>

                        <button type="submit" class="btn btn-dark w-100 py-2 fw-bold" style="border-radius: 10px;">
                            <i class="fas fa-user-plus me-2"></i> Assign Selected
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Student List -->
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm" style="border-radius: 15px;">
                <div class="card-header bg-white border-0 py-3 px-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold">Students List</h5>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="selectAll">
                            <label class="form-check-label small fw-bold text-muted" for="selectAll">Select All Visible</label>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-4 py-3" style="width: 50px;">Select</th>
                                    <th class="py-3">Student</th>
                                    <th class="py-3">Current Class</th>
                                    <th class="py-3">Status</th>
                                    <th class="py-3">Parent Info</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <input class="form-check-input student-checkbox" type="checkbox" name="studentIds" value="@item.StudentID" form="bulkForm">
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.PhotoPath))
                                                {
                                                    <img src="@item.PhotoPath" class="rounded-circle me-3" style="width: 40px; height: 40px; object-fit: cover; border: 2px solid #eee;">
                                                }
                                                else
                                                {
                                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px; font-weight: bold;">
                                                        @item.Name[0]
                                                    </div>
                                                }
                                                <div>
                                                    <div class="fw-bold text-dark">@item.Name</div>
                                                    <div class="small text-muted">ID: #@item.StudentID</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            @if (item.Admission != null && !string.IsNullOrEmpty(item.Admission.Class))
                                            {
                                                <span class="badge bg-soft-primary text-primary px-3 py-2 rounded-pill">
                                                    @item.Admission.Class - @item.Admission.Section
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-soft-danger text-danger px-3 py-2 rounded-pill">
                                                    Unassigned
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <span class="badge @(item.Status == "Active" ? "bg-success" : "bg-secondary") rounded-pill" style="font-size: 0.7rem;">
                                                @item.Status
                                            </span>
                                        </td>
                                        <td>
                                            <div class="small fw-600">@item.Parent?.FatherName</div>
                                            <div class="small text-muted">@item.MobileNo</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-search fa-3x text-light-emphasis mb-3"></i>
                            <h5 class="text-muted">No students found</h5>
                            <p class="text-muted small">Try adjusting your filters or search criteria.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary { background-color: rgba(59, 130, 246, 0.1); }
    .bg-soft-danger { background-color: rgba(239, 68, 68, 0.1); }
    .fw-600 { font-weight: 600; }
    .form-select:focus, .form-control:focus { box-shadow: 0 0 0 0.25rem rgba(59, 130, 246, 0.15); border-color: #3b82f6; }
    .student-checkbox { cursor: pointer; width: 1.2rem; height: 1.2rem; }
    .table-hover tbody tr:hover { background-color: rgba(59, 130, 246, 0.02); }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Select All functionality
            $('#selectAll').change(function () {
                $('.student-checkbox').prop('checked', $(this).prop('checked'));
                updateCount();
            });

            $('.student-checkbox').change(function () {
                updateCount();
                if (!$(this).prop('checked')) {
                    $('#selectAll').prop('checked', false);
                }
            });

            function updateCount() {
                var count = $('.student-checkbox:checked').length;
                if (count > 0) {
                    $('#selectedCount').text(count + ' students selected').fadeIn();
                } else {
                    $('#selectedCount').fadeOut();
                }
            }

            $('#bulkForm').submit(function (e) {
                var count = $('.student-checkbox:checked').length;
                if (count === 0) {
                    alert('Please select at least one student.');
                    e.preventDefault();
                }
            });
        });
    </script>
}
