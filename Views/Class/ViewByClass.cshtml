@model IEnumerable<StudentManagementSystem.Models.ClassSummaryViewModel>

@{
    ViewData["Title"] = "Students by Class";
}

<div class="container-fluid px-4 py-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1"><i class="fas fa-chalkboard-teacher me-2 text-primary"></i>Students by Class</h2>
            <p class="text-muted mb-0">Overview of student distribution across all academic classes.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="AssignStudents" class="btn btn-outline-primary rounded-pill px-4">
                <i class="fas fa-user-plus me-2"></i>Manage Assignments
            </a>
            <a asp-controller="Seed" asp-action="Index" class="btn btn-warning rounded-pill px-4 fw-bold">
                <i class="fas fa-seedling me-2"></i>Seed More Students
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-3 mb-4" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-xl-3 col-md-6">
                <div class="card border-0 shadow-sm rounded-4 h-100 class-card">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="bg-primary bg-opacity-10 text-primary p-3 rounded-3">
                                <i class="fas fa-school fs-4"></i>
                            </div>
                            <span class="badge bg-primary rounded-pill px-3 py-2">@item.StudentCount Students</span>
                        </div>
                        <h4 class="fw-bold mb-1">@item.ClassName</h4>
                        <p class="text-muted small mb-3">Session 2024-2025</p>
                        
                        <div class="d-flex gap-3 mb-4">
                            <div class="d-flex align-items-center">
                                <div class="dot bg-info me-2"></div>
                                <span class="small text-muted">@item.MaleCount Male</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <div class="dot bg-pink me-2"></div>
                                <span class="small text-muted">@item.FemaleCount Female</span>
                            </div>
                        </div>

                        <a asp-action="AssignStudents" asp-route-className="@item.ClassName" class="btn btn-light w-100 rounded-3 text-primary fw-semibold">
                            View Student List <i class="fas fa-arrow-right ms-1 small"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .class-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        border: 1px solid rgba(0,0,0,0.05) !important;
    }
    .class-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    .dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }
    .bg-pink { background-color: #e83e8c; }
    .bg-info { background-color: #0dcaf0; }
</style>
