@{
    ViewData["Title"] = "Fee Reports";
}

<div class="container-fluid mt-4">
    <div class="row g-4">
        <div class="col-md-4 col-lg-3">
            <partial name="_ReportsSidebar" />
        </div>
        <div class="col-md-8 col-lg-9">
            <div class="card border-0 shadow-sm d-flex align-items-center justify-content-center p-5 text-center bg-white" style="min-height: 500px;">
                <div class="text-muted">
                    <div class="mb-4">
                        <i class="fas fa-file-invoice-dollar fa-5x opacity-25 text-primary"></i>
                    </div>
                    <h3 class="fw-bold text-dark">Welcome to Fee Reports</h3>
                    <p class="lead">Select a report from the left sidebar to generate and view financial data.</p>
                    <div class="mt-4 pt-3 border-top w-50 mx-auto">
                        <div class="row text-start small">
                            <div class="col-6 mb-2"><i class="fas fa-check-circle text-success me-2"></i>Fee Collection</div>
                            <div class="col-6 mb-2"><i class="fas fa-check-circle text-success me-2"></i>Breakdown Analysis</div>
                            <div class="col-6 mb-2"><i class="fas fa-check-circle text-success me-2"></i>Payment Tracking</div>
                            <div class="col-6 mb-2"><i class="fas fa-check-circle text-success me-2"></i>Export Options</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
