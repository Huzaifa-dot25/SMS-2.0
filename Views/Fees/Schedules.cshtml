@model StudentManagementSystem.Models.FeeSchedule
@{
    ViewData["Title"] = "Fee Schedule";
}

<div class="container-fluid mt-2 px-0">
    <nav aria-label="breadcrumb" class="mx-3 mb-2">
        <div class="d-flex justify-content-between align-items-center w-100">
            <ol class="breadcrumb small mb-0">
                <li class="breadcrumb-item"><a asp-action="Index">Fees</a></li>
                <li class="breadcrumb-item active">Schedule</li>
            </ol>
            <a asp-action="ViewSchedules" class="btn btn-sm btn-outline-primary">
                <i class="fas fa-list me-1"></i> View All Schedules
            </a>
        </div>
    </nav>

    <div class="card border-0 shadow-sm mx-3 mb-4 overflow-hidden">
        <div class="card-header bg-dark-blue py-3">
            <h5 class="mb-0 text-white">Create Fee Schedule</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="SaveSchedule" method="post" id="scheduleForm">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-danger mb-3 small"></div>
                
                <div class="row g-4 mb-4">
                    <div class="col-md-4">
                        <label asp-for="ScheduleName" class="form-label small text-muted"></label>
                        <input asp-for="ScheduleName" class="form-control border-secondary-subtle" placeholder="e.g. Monthly Fee 2024" required />
                        <span asp-validation-for="ScheduleName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ClassID" class="form-label small text-muted"></label>
                        <select asp-for="ClassID" class="form-select border-secondary-subtle">
                            <option value="">--All Classes--</option>
                            @if (ViewBag.Classes != null)
                            {
                                foreach (var className in ViewBag.Classes)
                                {
                                    <option value="@className">@className</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="SurchargePercent" class="form-label small text-muted"></label>
                        <div class="input-group">
                            <input asp-for="SurchargePercent" type="number" step="0.01" class="form-control border-secondary-subtle" placeholder="0.00" />
                            <span class="input-group-text">%</span>
                        </div>
                    </div>
                </div>

                <div class="table-responsive mb-4">
                    <table class="table table-bordered align-middle" id="itemsTable">
                        <thead class="bg-light">
                            <tr>
                                <th class="fw-bold" style="width: 25%;">Frequency</th>
                                <th class="fw-bold" style="width: 40%;">Fee Type</th>
                                <th class="fw-bold" style="width: 25%;">Fee Amount</th>
                                <th class="fw-bold text-center" style="width: 10%;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="item-row">
                                <td>
                                    <select name="Items[0].Frequency" class="form-select form-select-sm border-0">
                                        <option value="Monthly">Monthly</option>
                                        <option value="One-Time">One-Time</option>
                                    </select>
                                </td>
                                <td>
                                    <input name="Items[0].FeeType" type="text" class="form-control form-control-sm border-0" placeholder="e.g. Tuition Fee" required>
                                </td>
                                <td>
                                    <input name="Items[0].FeeAmount" type="number" step="0.01" class="form-control form-control-sm border-0" placeholder="0.00" required>
                                </td>
                                <td class="text-center">
                                    <button type="button" class="btn btn-sm text-danger remove-row"><i class="fas fa-trash"></i></button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-success px-4" id="addRow">
                        <i class="fas fa-plus me-1"></i> Add Row
                    </button>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save me-1"></i> Save Schedule
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            let rowCount = 1;

            $('#addRow').click(function () {
                const newRow = `
                    <tr class="item-row">
                        <td>
                            <select name="Items[${rowCount}].Frequency" class="form-select form-select-sm border-0">
                                <option value="Monthly">Monthly</option>
                                <option value="One-Time">One-Time</option>
                            </select>
                        </td>
                        <td>
                            <input name="Items[${rowCount}].FeeType" type="text" class="form-control form-control-sm border-0" placeholder="e.g. Tuition Fee" required>
                        </td>
                        <td>
                            <input name="Items[${rowCount}].FeeAmount" type="number" step="0.01" class="form-control form-control-sm border-0" placeholder="0.00" required>
                        </td>
                        <td class="text-center">
                            <button type="button" class="btn btn-sm text-danger remove-row"><i class="fas fa-trash"></i></button>
                        </td>
                    </tr>
                `;
                $('#itemsTable tbody').append(newRow);
                rowCount++;
            });

            $(document).on('click', '.remove-row', function () {
                if ($('.item-row').length > 1) {
                    $(this).closest('tr').remove();
                    reindexRows();
                } else {
                    alert('At least one item is required.');
                }
            });

            function reindexRows() {
                let currentCount = 0;
                $('.item-row').each(function () {
                    $(this).find('select, input').each(function () {
                        const name = $(this).attr('name');
                        if (name) {
                            const newName = name.replace(/Items\[\d+\]/, `Items[${currentCount}]`);
                            $(this).attr('name', newName);
                        }
                    });
                    currentCount++;
                });
                rowCount = currentCount;
            }
        });
    </script>
}

<style>
    .bg-dark-blue {
        background-color: #1a237e;
    }
    .table thead th {
        font-size: 0.9rem;
        color: #333;
        border-bottom: 2px solid #dee2e6;
    }
    .form-label {
        font-weight: 600;
    }
    .form-control:focus, .form-select:focus {
        box-shadow: none;
        border-color: #1a237e;
    }
</style>
