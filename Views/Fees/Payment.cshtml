@{
    ViewData["Title"] = "Upload Payments";
}

<div class="container-fluid mt-2 px-0">
    <nav aria-label="breadcrumb" class="mx-3 mb-2">
        <ol class="breadcrumb small">
            <li class="breadcrumb-item"><a asp-action="Index">Fees</a></li>
            <li class="breadcrumb-item active">Upload Payments</li>
        </ol>
    </nav>

    <div class="card border-0 shadow-sm mx-3 mb-4 overflow-hidden">
        <div class="card-header bg-dark-blue py-2 px-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-white">Upload Payments</h5>
            <button class="btn btn-sm btn-light fw-bold">
                <i class="fas fa-download me-1"></i> Download Sample Excel
            </button>
        </div>
        <div class="card-body p-4">
            <div class="row g-4 mb-4">
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Bank Name <span class="text-danger">*</span></label>
                    <select class="form-select border-secondary-subtle">
                        <option selected>--Select Bank--</option>
                        <option>Bank Alfalah</option>
                        <option>HBL</option>
                        <option>Meezan Bank</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-bold">Select Excel file (.xlsx) <span class="text-danger">*</span></label>
                    <input type="file" class="form-control border-secondary-subtle">
                </div>
            </div>

            <div class="alert alert-instructions border-0 p-4 mb-4 rounded-3">
                <h6 class="fw-bold mb-3 text-dark">Excel Upload Instructions:</h6>
                <ul class="small mb-4 text-dark">
                    <li><strong>Download the sample Excel template</strong> using the button above for correct format</li>
                    <li><strong>Column A:</strong> Payment Date (MM/dd/yyyy format)</li>
                    <li><strong>Column B:</strong> Challan UID (numeric ID of the challan)</li>
                    <li><strong>Column C:</strong> Amount Paid (numeric value without currency symbol)</li>
                </ul>
                <h6 class="fw-bold mb-3 text-dark">Important Notes:</h6>
                <ul class="small mb-0 text-dark">
                    <li>The selected bank will be applied to all payments in the Excel file</li>
                    <li>Make sure all payments in your file are from the same bank</li>
                    <li>Ensure challan Exsist exist in the system and amounts match exactly</li>
                </ul>
            </div>

            <button type="button" class="btn btn-primary px-4 py-2">
                <i class="fas fa-upload me-2"></i>Upload and Process
            </button>
        </div>
    </div>
</div>

<style>
    .bg-dark-blue {
        background-color: #1a237e;
    }
    .alert-instructions {
        background-color: #e0f2f1;
        border-left: 5px solid #009688 !important;
    }
    .alert-instructions ul li {
        margin-bottom: 8px;
    }
</style>
