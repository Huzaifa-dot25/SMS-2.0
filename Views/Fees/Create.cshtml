@model StudentManagementSystem.Models.FeeChallan
@{
    ViewData["Title"] = "Create Single Challan";
    var students = ViewBag.Students as List<StudentManagementSystem.Models.Student>;
}

<div class="container-fluid mt-2 px-0">
    <div class="card border-0 shadow-sm mx-3 overflow-hidden">
        <div class="card-header bg-dark-blue py-3 px-4">
            <h5 class="mb-0 text-white fw-bold"><i class="fas fa-plus-circle me-2"></i>Create Single Challan</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="StudentID" class="form-label small fw-bold">Select Student *</label>
                        <select asp-for="StudentID" class="form-select border-secondary-subtle select2">
                            <option value="">-- Search Student --</option>
                            @if (students != null)
                            {
                                foreach (var s in students)
                                {
                                    <option value="@s.StudentID">@s.Name (ID: @s.StudentID)</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="StudentID" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ChallanID" class="form-label small fw-bold">Challan ID (Optional)</label>
                        <input asp-for="ChallanID" class="form-control border-secondary-subtle" placeholder="Leave blank to auto-generate" />
                        <span asp-validation-for="ChallanID" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ClassName" class="form-label small fw-bold">Class Name *</label>
                        <input asp-for="ClassName" class="form-control border-secondary-subtle" placeholder="e.g. Class 5-A" />
                        <span asp-validation-for="ClassName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Month" class="form-label small fw-bold">Fee Month *</label>
                        <input asp-for="Month" class="form-control border-secondary-subtle" placeholder="e.g. May-26" />
                        <span asp-validation-for="Month" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Amount" class="form-label small fw-bold">Amount *</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-secondary-subtle">Rs.</span>
                            <input asp-for="Amount" class="form-control border-secondary-subtle" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="DueDate" class="form-label small fw-bold">Due Date *</label>
                        <input asp-for="DueDate" type="date" class="form-control border-secondary-subtle" />
                        <span asp-validation-for="DueDate" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Status" class="form-label small fw-bold">Status</label>
                        <select asp-for="Status" class="form-select border-secondary-subtle">
                            <option value="Unpaid">Unpaid</option>
                            <option value="Paid">Paid</option>
                            <option value="Expired">Expired</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-5">
                    <a asp-action="Challans" class="btn btn-light px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-5 fw-bold">Create Challan</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .bg-dark-blue {
        background-color: #1a237e;
    }
    .form-label {
        color: #555;
    }
    .select2-container--default .select2-selection--single {
        height: 38px;
        border: 1px solid #dee2e6;
        border-radius: 0.375rem;
        padding-top: 5px;
    }
</style>

@section Scripts {
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    
    <script>
        $(document).ready(function() {
            $('.select2').select2({
                placeholder: "-- Search Student --",
                allowClear: true
            });

            $('#StudentID').on('change', function() {
                var studentId = $(this).val();
                if (studentId) {
                    $.get('/Fees/GetStudentDetails/' + studentId, function(data) {
                        if (data && data.className) {
                            $('#ClassName').val(data.className);
                        }
                    });
                }
            });
        });
    </script>
}
