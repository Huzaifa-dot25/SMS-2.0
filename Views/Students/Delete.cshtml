@model StudentManagementSystem.Models.Student

@{
    ViewData["Title"] = "Delete Student";
}

<div class="container mt-4">
    <h2 class="text-danger">Delete Student</h2>
    <hr />
    
    <div class="card border-danger shadow-sm mb-4">
        <div class="card-body">
            <h4 class="card-title text-danger mb-4">Are you sure you want to delete this student?</h4>
            <div class="row">
                <div class="col-md-2">
                    @if (!string.IsNullOrEmpty(Model.PhotoPath))
                    {
                        <img src="@Model.PhotoPath" class="img-fluid rounded shadow-sm" style="max-height: 150px;" />
                    }
                    else
                    {
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center rounded" style="width: 150px; height: 150px;">
                            <i class="fas fa-user-slash fa-4x"></i>
                        </div>
                    }
                </div>
                <div class="col-md-10">
                    <dl class="row">
                        <dt class="col-sm-3">Name</dt>
                        <dd class="col-sm-9">@Model.Name</dd>

                        <dt class="col-sm-3">Date of Birth</dt>
                        <dd class="col-sm-9">@Model.DateOfBirth.ToShortDateString()</dd>

                        <dt class="col-sm-3">Gender</dt>
                        <dd class="col-sm-9">@Model.Gender</dd>
                    </dl>
                </div>
            </div>
        </div>
        <div class="card-footer bg-light p-3">
            <form asp-action="Delete">
                <input type="hidden" asp-for="StudentID" />
                <button type="submit" class="btn btn-danger px-4 me-2">
                    <i class="fas fa-trash-alt me-1"></i> Delete Permanentely
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
            </form>
        </div>
    </div>
</div>
