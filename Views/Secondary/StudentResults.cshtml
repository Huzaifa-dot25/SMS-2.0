@model StudentManagementSystem.Models.StudentResultViewModel
@{
    ViewData["Title"] = "Student Result Card";
}

<!-- Print Button (hidden when printing) -->
<div class="d-flex justify-content-between align-items-center mb-3 no-print">
    <div>
        <a asp-controller="Students" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i> Back to Students
        </a>
    </div>
    <div class="d-flex gap-2 align-items-center">
        @if (Model.AvailableSessions.Any())
        {
            <form method="get" class="d-flex gap-2 align-items-center">
                <input type="hidden" name="studentId" value="@Model.Student.StudentID" />
                <select name="session" class="form-select form-select-sm" onchange="this.form.submit()">
                    @foreach (var s in Model.AvailableSessions)
                    {
                        <option value="@s" selected="@(s == Model.SelectedSession)">@s</option>
                    }
                </select>
            </form>
        }
        <button onclick="window.print()" class="btn btn-primary btn-sm px-4">
            <i class="fas fa-print me-2"></i>Print Result
        </button>
    </div>
</div>

<!-- Result Card (printed) -->
<div class="result-card card border-0 shadow-sm" id="printArea">

    <!-- Header -->
    <div class="card-header bg-primary text-white py-4 text-center">
        <h4 class="mb-1 fw-bold"><i class="fas fa-graduation-cap me-2"></i>Student Result Card</h4>
        @if (!string.IsNullOrEmpty(Model.SelectedSession))
        {
            <p class="mb-0 opacity-75">Session: @Model.SelectedSession</p>
        }
    </div>

    <div class="card-body p-4">

        <!-- Student Info -->
        <div class="row mb-4 align-items-center">
            <div class="col-auto">
                @if (!string.IsNullOrEmpty(Model.Student.PhotoPath))
                {
                    <img src="@Model.Student.PhotoPath" class="rounded-circle border shadow-sm"
                         style="width:80px;height:80px;object-fit:cover;" alt="Photo" />
                }
                else
                {
                    <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center"
                         style="width:80px;height:80px;">
                        <i class="fas fa-user fa-2x text-secondary"></i>
                    </div>
                }
            </div>
            <div class="col">
                <h5 class="fw-bold mb-1">@Model.Student.Name</h5>
                <div class="row g-2 text-muted small">
                    <div class="col-auto"><i class="fas fa-id-badge me-1"></i>ID: @Model.Student.StudentID</div>
                    @if (!string.IsNullOrEmpty(Model.Student.Admission?.RollNo))
                    {
                        <div class="col-auto"><i class="fas fa-hashtag me-1"></i>Roll No: @Model.Student.Admission.RollNo</div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Student.Admission?.Class))
                    {
                        <div class="col-auto"><i class="fas fa-chalkboard me-1"></i>Class: @Model.Student.Admission.Class @Model.Student.Admission.Section</div>
                    }
                    <div class="col-auto"><i class="fas fa-venus-mars me-1"></i>@Model.Student.Gender</div>
                </div>
            </div>
            @if (Model.Results.Any())
            {
                <div class="col-auto text-end">
                    <div class="border rounded-3 p-3 text-center" style="min-width:110px;">
                        <div class="display-6 fw-bold text-primary">@Model.Grade</div>
                        <div class="small text-muted">@Model.Percentage%</div>
                        <div class="small text-muted">Overall</div>
                    </div>
                </div>
            }
        </div>

        @if (!Model.Results.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-clipboard fa-3x mb-3 opacity-25"></i>
                <p class="mb-0">No results found for this student@(Model.SelectedSession != null ? " in session " + Model.SelectedSession : "").</p>
            </div>
        }
        else
        {
            <!-- Group results by Term -->
            @foreach (var termGroup in Model.Results.GroupBy(r => r.Term).OrderBy(g => g.Key))
            {
                var termObtained = termGroup.Where(r => r.Status == "Present").Sum(r => r.ObtainedMarks);
                var termTotal = termGroup.Where(r => r.Status == "Present").Sum(r => r.TotalMarks);
                var termPct = termTotal > 0 ? Math.Round((termObtained / termTotal) * 100, 1) : 0;

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="fw-bold text-uppercase text-primary mb-0">
                            <i class="fas fa-bookmark me-2"></i>@termGroup.Key
                        </h6>
                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2">
                            @termObtained / @termTotal &nbsp;|&nbsp; @termPct%
                        </span>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-sm align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Subject</th>
                                    <th>Sub-Subject</th>
                                    <th>Exam Type</th>
                                    <th class="text-center">Total Marks</th>
                                    <th class="text-center">Obtained</th>
                                    <th class="text-center">%</th>
                                    <th class="text-center">Status</th>
                                    <th class="text-center">Announced</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in termGroup.OrderBy(r => r.Subject))
                                {
                                    var pct = r.TotalMarks > 0 ? Math.Round((r.ObtainedMarks / r.TotalMarks) * 100, 1) : 0;
                                    var rowClass = r.Status == "Absent" ? "table-danger" : r.Status == "Present" && pct < 50 ? "table-warning" : "";
                                    <tr class="@rowClass">
                                        <td class="fw-semibold">@r.Subject</td>
                                        <td class="text-muted small">@r.SubSubject</td>
                                        <td><span class="badge bg-secondary bg-opacity-10 text-secondary">@r.ExamType</span></td>
                                        <td class="text-center">@r.TotalMarks</td>
                                        <td class="text-center fw-bold">
                                            @(r.Status == "Absent" ? "-" : r.ObtainedMarks.ToString())
                                        </td>
                                        <td class="text-center">
                                            @(r.Status == "Absent" ? "-" : pct + "%")
                                        </td>
                                        <td class="text-center">
                                            @if (r.Status == "Present")
                                            {
                                                <span class="badge bg-success">Present</span>
                                            }
                                            else if (r.Status == "Absent")
                                            {
                                                <span class="badge bg-danger">Absent</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@r.Status</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (r.IsAnnounced)
                                            {
                                                <i class="fas fa-check-circle text-success"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-clock text-warning"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light fw-bold">
                                <tr>
                                    <td colspan="3">Term Total</td>
                                    <td class="text-center">@termTotal</td>
                                    <td class="text-center">@termObtained</td>
                                    <td class="text-center">@termPct%</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            }

            <!-- Overall Summary -->
            <div class="row g-3 mt-2">
                <div class="col-md-3 col-6">
                    <div class="border rounded-3 p-3 text-center">
                        <div class="h5 fw-bold text-primary mb-0">@Model.TotalObtained</div>
                        <div class="small text-muted">Total Obtained</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="border rounded-3 p-3 text-center">
                        <div class="h5 fw-bold text-secondary mb-0">@Model.TotalMarks</div>
                        <div class="small text-muted">Total Marks</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="border rounded-3 p-3 text-center">
                        <div class="h5 fw-bold text-success mb-0">@Model.Percentage%</div>
                        <div class="small text-muted">Percentage</div>
                    </div>
                </div>
                <div class="col-md-3 col-6">
                    <div class="border rounded-3 p-3 text-center">
                        <div class="h5 fw-bold text-warning mb-0">@Model.Grade</div>
                        <div class="small text-muted">Grade</div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="card-footer text-muted small text-center py-3">
        Printed on @DateTime.Now.ToString("dd MMM yyyy, hh:mm tt") &mdash; Student Management System
    </div>
</div>

@section Scripts {
<style>
    @@media print {
        .no-print, .sidebar, .top-bar, nav, header { display: none !important; }
        .main-wrapper { margin-left: 0 !important; }
        .result-card { box-shadow: none !important; border: 1px solid #ddd !important; }
        body { background: white !important; }
        .card-header { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .badge { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .table-danger { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .table-warning { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .table-light { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
    }
</style>
}
