@{
    ViewData["Title"] = "Secondary Dashboard";
}

<div class="container-fluid">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 hover-card">
                <div class="icon-box bg-primary-light mb-3 mx-auto">
                    <i class="fas fa-calendar-check fa-2x text-primary"></i>
                </div>
                <h5 class="fw-bold">Manage Results</h5>
                <p class="text-muted small">Enter and update student examination marks.</p>
                <a asp-action="ManageResult" class="btn btn-outline-primary rounded-pill stretched-link">Go to Results</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 hover-card">
                <div class="icon-box bg-success-light mb-3 mx-auto">
                    <i class="fas fa-table-cells fa-2x text-success"></i>
                </div>
                <h5 class="fw-bold">Results Grid</h5>
                <p class="text-muted small">View comprehensive results across classes.</p>
                <a asp-action="ResultsGrid" class="btn btn-outline-success rounded-pill stretched-link">View Grid</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4 h-100 hover-card">
                <div class="icon-box bg-info-light mb-3 mx-auto">
                    <i class="fas fa-print fa-2x text-info"></i>
                </div>
                <h5 class="fw-bold">Print Reports</h5>
                <p class="text-muted small">Generate and print student report cards.</p>
                <a asp-action="PrintResult" class="btn btn-outline-info rounded-pill stretched-link">Print Now</a>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-primary-light { background-color: rgba(54, 153, 255, 0.1); }
    .bg-success-light { background-color: rgba(27, 197, 189, 0.1); }
    .bg-info-light { background-color: rgba(137, 80, 252, 0.1); }
    .icon-box { width: 60px; height: 60px; display: flex; align-items: center; justify-content: center; border-radius: 12px; }
    .hover-card { transition: transform 0.2s; cursor: pointer; }
    .hover-card:hover { transform: translateY(-5px); }
</style>
